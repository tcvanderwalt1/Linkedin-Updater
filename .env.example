# Neon Serverless Postgres (use pooled / PgBouncer host when available)
# Example: postgresql://app:SECRET@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://app:CHANGE_ME@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional: integration tests only (never use production DB)
# TEST_DATABASE_URL=

# Search provider: exa | tavily
SEARCH_PROVIDER=exa
EXA_API_KEY=
TAVILY_API_KEY=

# LLM provider: gemini | grok | claude
LLM_PROVIDER=gemini
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-2-latest
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8501/

# Failure notifications (Slack or Discord incoming webhook)
WEBHOOK_URL=

# Streamlit app password gate
APP_PASSWORD=change-me

# Pipeline behaviour
EMPTY_DAY_EXIT_ZERO=true
TOP_ARTICLES=10
TOP_DRAFTS=3
DEDUPE_DAYS=30
